<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Cpp2IL / Disarm / LibCpp2IL author feed (hosts Disarm 2022.1.0-master.99 that Cpp2IL pre-release.21 depends on) -->
    <add key="samboy" value="https://nuget.samboy.dev/v3/index.json" />
    <!-- BepInEx feed (Il2CppInterop CI builds, dotnet-runtime, etc.) -->
    <add key="bepinex" value="https://nuget.bepinex.dev/v3/index.json" />
  </packageSources>
</configuration>
